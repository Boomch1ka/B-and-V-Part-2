@model B_and_V_Part_2.Models.Event
@{
    ViewData["Title"] = "Edit Event";
}
<h2>Edit Event</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="EventId" />
    <input type="hidden" asp-for="ImageUrl" />
    <div class="mb-3">
        <label asp-for="EventTypeId" class="form-label">Event Type</label>
        <select asp-for="EventTypeId" asp-items="ViewBag.EventTypeId" class="form-select">
            <option value="">-- Select Type --</option>
        </select>
    </div>
    <div class="mb-3">
        <label class="form-label">Name</label>
        <input asp-for="EventName" class="form-control" />
        <span asp-validation-for="EventName" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label class="form-label">Date</label>
        <input asp-for="EventDate" type="date" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Description</label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
    </div>
    <div class="mb-3">
        <label class="form-label">Current Image</label><br />
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" alt="Current image"
                 style="max-height:120px;border-radius:6px;" class="mb-2" />
        }
        else
        {
            <span class="text-muted">No image uploaded</span>
        }
    </div>
    <div class="mb-3">
        <label class="form-label">Replace Image (optional)</label>
        <input type="file" name="imageFile" class="form-control" accept="image/*" />
    </div>
    <div>
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
    </div>
</form>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}