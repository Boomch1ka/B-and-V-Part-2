@model IEnumerable<B_and_V_Part_2.Models.Event>
@{
    ViewData["Title"] = "Events";
    var search = ViewData["Search"] as string;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Events</h2>
    <a class="btn btn-primary" asp-action="Create">New Event</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <input type="text" name="search" value="@search" class="form-control" placeholder="Search events or description" />
    </div>
    <div class="col-auto">
        <button class="btn btn-outline-secondary" type="submit">Search</button>
    </div>
</form>

<table class="table table-hover">
    <thead>
        <tr>
            <th>Name</th>
            <th>Date</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach(var e in Model) {
    <tr>
        <td>@e.EventName</td>
        <td>@e.EventDate.ToString("yyyy-MM-dd")</td>
        <td>
            <a class="btn btn-sm btn-outline-secondary me-1" asp-action="Details" asp-route-id="@e.EventId">Details</a>
            <a class="btn btn-sm btn-outline-primary me-1" asp-action="Edit" asp-route-id="@e.EventId">Edit</a>
            <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@e.EventId">Delete</a>
        </td>
    </tr>
}
    </tbody>
</table>
