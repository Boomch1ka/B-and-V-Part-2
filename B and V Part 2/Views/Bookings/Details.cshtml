@model B_and_V_Part_2.Models.Booking
@{
    ViewData["Title"] = "Booking Details";
}

<h2>Booking Details</h2>
<div class="card">
    <div class="card-body">
        <h5 class="card-title">@Model.Event?.EventName - @Model.Venue?.VenueName</h5>
        <p class="card-text">Date: @Model.BookingDate.ToString("yyyy-MM-dd")</p>
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </div>
</div>
