@model IEnumerable<B_and_V_Part_2.Models.Booking>
@{
    ViewData["Title"] = "Bookings";
    var search = ViewData["Search"] as string;
    var date = ViewData["Date"] as string;
    var page = ViewData["Page"] != null ? (int)ViewData["Page"] : 1;
    var totalPages = ViewData["TotalPages"] != null ? (int)ViewData["TotalPages"] : 1;
    var totalCount = ViewData["TotalCount"] != null ? (int)ViewData["TotalCount"] : 0;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Bookings <small class="text-muted">(@totalCount)</small></h2>
    <a class="btn btn-primary" asp-action="Create">New Booking</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <input type="text" name="search" value="@search" class="form-control" placeholder="Search venue or event" />
    </div>
    <div class="col-auto">
        <input type="date" name="date" value="@date" class="form-control" />
    </div>
    <div class="col-auto">
        <button class="btn btn-outline-secondary" type="submit">Search</button>
    </div>
</form>

<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th>Date</th>
            <th>Venue</th>
            <th>Event</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach(var b in Model) {
    <tr>
        <td>@b.BookingDate.ToString("yyyy-MM-dd")</td>
        <td>
            <div class="d-flex align-items-center">
                @if(!string.IsNullOrEmpty(b.Venue?.ImageUrl))
                {
                    <img src="@b.Venue.ImageUrl" alt="@b.Venue.VenueName" class="me-2" style="width:64px;height:44px;object-fit:cover;border-radius:6px;" />
                }
                <div>
                    <div>@b.Venue?.VenueName</div>
                    <small class="text-muted">@b.Venue?.Location</small>
                </div>
            </div>
        </td>
        <td>
            <div>@b.Event?.EventName</div>
            <small class="text-muted">@b.Event?.EventDate.ToString("yyyy-MM-dd")</small>
        </td>
        <td>
            <a class="btn btn-sm btn-outline-secondary me-1" asp-action="Details" asp-route-id="@b.BookingId">Details</a>
            <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@b.BookingId">Delete</a>
        </td>
    </tr>
}
    </tbody>
</table>

<nav aria-label="Page navigation">
    <ul class="pagination">
        <li class="page-item @(page <= 1 ? "disabled" : "")">
            <a class="page-link" href="?search=@search&date=@date&page=@(page-1)">Previous</a>
        </li>
        @for (int p = 1; p <= totalPages; p++)
        {
            <li class="page-item @(p == page ? "active" : "")"><a class="page-link" href="?search=@search&date=@date&page=@p">@p</a></li>
        }
        <li class="page-item @(page >= totalPages ? "disabled" : "")">
            <a class="page-link" href="?search=@search&date=@date&page=@(page+1)">Next</a>
        </li>
    </ul>
</nav>
